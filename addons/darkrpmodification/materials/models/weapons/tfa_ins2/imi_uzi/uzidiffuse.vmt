// Override Uzi diffuse: новый скин (синий с MLG/C9/G2 логотипами).
// Параметры material — копия оригинала из z_city_content_1.
// $bumpmap и $phongexponenttexture ссылаются на оригинальные normal/gloss
// из workshop addon — переопределяем ТОЛЬКО диффузную текстуру.
VertexLitGeneric
{
	"$baseTexture" 			"models/weapons/tfa_ins2/imi_uzi/uzidiffuse"
	"$bumpmap"     			"models/weapons/tfa_ins2/imi_uzi/uzinormal"
	"$phongexponenttexture" 	"models/weapons/tfa_ins2/imi_uzi/uzigloss"

	"$nocull"	"1"

	"$normalmapalphaenvmapmask" "1"
	"$color"			"[1 1 1]"

	"$envmap" 			"env_cubemap"
	"$envmaptint" 			"[.007 .007 .007]"

	"$phong"                        "1"
	"$phongalbedotint"              "1"
	"$phongtint"                    "[.6 .8 1]"
	"$phongexponent"		"55"
	"$phongboost" 			"1.2"
	"$phongfresnelranges"		"[0.5 1.5 3.0]"
	"$halflambert"			"1"
}
